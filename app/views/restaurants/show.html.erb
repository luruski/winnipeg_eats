<% content_for :title, @restaurant.name %>

<h1><%= @restaurant.name %></h1>

<%# feature 5.2 - conditional, some restaurants have no address in the OSM data %>
<% if @restaurant.address.strip == "" %>
  <p class="text-muted">No address available</p>
<% else %>
  <p><%= @restaurant.address %>, Winnipeg</p>
<% end %>

<h4>Cuisines</h4>
<p>
  <% @restaurant.cuisines.each do |cuisine| %>
    <%= link_to cuisine.name, cuisine_path(cuisine), class: "badge bg-secondary text-decoration-none" %>
  <% end %>
</p>

<%# feature 3.6 - map of where the restaurant is using leaflet %>
<h4>Location</h4>
<div id="map" style="height: 300px;" class="mb-4 rounded"></div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  var map = L.map("map").setView([<%= @restaurant.lat %>, <%= @restaurant.lng %>], 16);

  L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
    attribution: "&copy; OpenStreetMap contributors"
  }).addTo(map);

  L.marker([<%= @restaurant.lat %>, <%= @restaurant.lng %>]).addTo(map)
    .bindPopup("<%= @restaurant.name %>");
</script>

<h4>Reviews</h4>
<% @restaurant.reviews.each do |review| %>
  <div class="card mb-2">
    <div class="card-body">
      <strong><%= review.author %></strong> <%= "★" * review.rating %><%= "☆" * (5 - review.rating) %>
      <p class="mb-0"><%= review.body %></p>
    </div>
  </div>
<% end %>