<% content_for :title, @cuisine.name %>
<p>Cuisine: <%= link_to @meal.cuisine.name, cuisine_path(@meal.cuisine) %></p>

<div class="row">
  <div class="col-md-4">
    <img src="<%= @meal.thumbnail %>" class="img-fluid rounded" alt="photo of <%= @meal.name %>">

    <h4 class="mt-3">Ingredients</h4>
    <ul>
      <% @meal.meal_ingredients.each do |mi| %>
        <li><%= mi.measure %> <%= mi.ingredient.name %></li>
      <% end %>
    </ul>
  </div>
  <div class="col-md-8">
    <h4>Instructions</h4>
    <p><%= simple_format(@meal.instructions) %></p>
  </div>
</div>