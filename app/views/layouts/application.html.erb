<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Winnipeg Eats" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to "Winnipeg Eats", root_path, class: "navbar-brand" %>
        <div class="navbar-nav">
          <%= link_to "Restaurants", restaurants_path, class: "nav-link" %>
          <%= link_to "Cuisines", cuisines_path, class: "nav-link" %>
          <%= link_to "Meals", meals_path, class: "nav-link" %>
          <%= link_to "About", about_path, class: "nav-link" %>
        </div>
      </div>
    </nav>

    <div class="container">
      <%= yield %>
    </div>

    <footer class="text-center text-muted py-4 mt-4 border-top">
      <p>Winnipeg Eats - restaurant data from OpenStreetMap, recipes from TheMealDB</p>
    </footer>
  </body>
</html>
    
  </body>
</html>